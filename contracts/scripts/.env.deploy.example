# Soroban / Stellar testnet deployment configuration
# Copy this file to .env.deploy and fill in your values.
# NEVER commit .env.deploy — it is listed in .gitignore.

# Testnet RPC endpoint (default Stellar testnet)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase for testnet
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Source account: the secret key (S...) or a named identity managed by stellar CLI.
# To create a funded testnet identity:
#   stellar keys generate --global deployer --network testnet
#   stellar keys fund deployer --network testnet
STELLAR_SOURCE_ACCOUNT=deployer
